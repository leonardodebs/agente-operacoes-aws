# Configuracao de ambiente do agente-operacoes-aws.
# Copie para .env e preencha. NUNCA versione o .env real.

# Regiao AWS onde a infra e provisionada.
AWS_DEFAULT_REGION=us-west-2

# --- Slack (em producao ficam no Secrets Manager, nunca no codigo) ---
# Usados apenas para testes locais e para popular o secret na primeira vez.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# --- Bedrock Agent (preenchidos via `terraform output`) ---
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
